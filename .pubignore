# Exclude development-only content from the published pub package.
# When this file is present, it replaces .gitignore for pub publishing.

# Standard Dart / IDE / OS exclusions
.dart_tool/
.packages
build/
pubspec.lock
pubspec_overrides.yaml
coverage/
doc/api/
.idea/
*.iml
.vscode/
.DS_Store

# Pub-specific exclusions — not needed at runtime by package consumers:

# All internal docs (architecture decisions, planning, ACP spec mirror,
# upstream references). The package homepage and pub.dev README link out
# to the published versions.
doc/

# Marketing website (deployed separately)
website/

# Codegen tooling and the bundled upstream schemas it consumes
tool/

# Test suite — not needed by package consumers
test/
dart_test.yaml

# Developer task runner — not useful to consumers
justfile
